{
  "name": "meetergo-integration",
  "version": "0.0.1",
  "description": "Integrate meetergo booking pages inside your website",
  "author": "meetergo <info@meetergo.com>",
  "repository": "https://github.com/meetergo/meetergo-integration",
  "license": "UNLICENSED",
  "keywords": [
    "meetergo"
  ],
  "browser": "./dist/esbuild/browser.js",
  "scripts": {
    "cli": "ts-node src/cli.ts",
    "lint": "eslint src/ --ext .js,.jsx,.ts,.tsx",
    "test": "jest",
    "clean": "rm -rf dist build package",
    "ts-node": "ts-node",
    "docs": "typedoc --entryPoints src/main.ts",
    "build": "tsc -p tsconfig.json",
    "build-all": "npm run clean && npm run esbuild-browser",
    "esbuild-browser": "esbuild src/browser.ts --bundle --minify --jsx=automatic --jsx-dev=false --external:react --external:react-dom --sourcemap=external  --tree-shaking=true --outfile=dist/esbuild/browser.js",
    "esbuild-browser:ultra": "esbuild src/browser.ts --bundle --minify --target=es2019 --format=iife --tree-shaking=true --drop:console --drop:debugger --legal-comments=none --charset=utf8 --outfile=dist/esbuild/browser-ultra.js",
    "esbuild-browser:dev": "esbuild src/browser.ts --bundle --outfile=dist/esbuild/browser.js",
    "esbuild-browser:watch": "esbuild src/browser.ts --bundle --watch --outfile=dist/esbuild/browser.js",
    "esbuild-node": "esbuild src/cli.ts --bundle --platform=node --minify --sourcemap=external --outfile=dist/esbuild/cli.js",
    "esbuild-node:dev": "esbuild src/cli.ts --bundle --platform=node --sourcemap=external --outfile=dist/esbuild/cli.js",
    "esbuild-node:watch": "esbuild src/cli.ts --bundle --platform=node --watch --sourcemap=external --outfile=dist/esbuild/cli.js",
    "deploy-prod": "aws s3 rm s3://liv-showcase/browser-v2.js && aws s3 cp dist/esbuild/browser.js s3://liv-showcase/browser-v2.js",
    "build-v4": "npm run esbuild-v4-browser && npm run esbuild-v4-browser:ultra",
    "esbuild-v4-browser": "esbuild src/v4/browser.ts --bundle --minify --target=es2019 --format=iife --tree-shaking=true --sourcemap=external --charset=utf8 --outfile=dist/v4/browser.js",
    "esbuild-v4-browser:ultra": "esbuild src/v4/browser.ts --bundle --minify --target=es2019 --format=iife --tree-shaking=true --drop:console --drop:debugger --legal-comments=none --charset=utf8 --outfile=dist/v4/browser-ultra.js",
    "esbuild-v4-browser:dev": "esbuild src/v4/browser.ts --bundle --sourcemap=inline --outfile=dist/v4/browser.js",
    "esbuild-v4-browser:watch": "esbuild src/v4/browser.ts --bundle --watch --sourcemap=inline --outfile=dist/v4/browser.js",
    "esbuild-v4-esm": "esbuild src/v4/index.ts --bundle --format=esm --external:react --external:react-dom --minify --outfile=dist/v4/index.esm.js",
    "deploy-v4-prod": "npm run build-v4 && bash scripts/deploy-cdn.sh"
  },
  "dependencies": {
    "esbuild": "^0.25.1"
  },
  "devDependencies": {
    "@types/jest": "^26.0.21",
    "@types/node": "^15.0.1",
    "@typescript-eslint/eslint-plugin": "^4.19.0",
    "@typescript-eslint/parser": "^4.19.0",
    "esbuild": "^0.25.1",
    "eslint": "^7.22.0",
    "jest": "^26.6.3",
    "ts-jest": "^26.5.4",
    "ts-node": "^9.1.1",
    "typedoc": "^0.20.35",
    "typescript": "4.2.3"
  }
}
